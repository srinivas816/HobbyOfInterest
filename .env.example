# Public API base URL. Leave empty to use same-origin /api (Vite proxy in dev, or reverse proxy in prod).
# Example production: VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=

# Dev only: Vite proxy target for /api — must match server PORT (see server/.env), e.g. PORT=3003 →
# VITE_DEV_API_ORIGIN=http://localhost:3003

# Instructor-first MVP: simplified nav, hide non-core marketplace UI, emphasize invites & studio.
# VITE_MVP_INSTRUCTOR_FOCUS=1
