generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  INSTRUCTOR
}

enum PlanTier {
  EXPLORER
  CREATOR_PLUS
  INSTRUCTOR_PRO
}

enum CourseFormat {
  ONLINE
  IN_PERSON
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum FeePaymentStatus {
  PENDING
  PAID
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  passwordHash        String
  /// E.164 style, e.g. +9198xxxxxxxxx — optional; used for phone OTP login
  phone               String?       @unique
  name                String
  role                Role          @default(LEARNER)
  planTier            PlanTier      @default(EXPLORER)
  specialty           String?
  instructorStudents  Int           @default(0)
  instructorClasses   Int           @default(0)
  /// Saved onboarding selections (learner or instructor shape). Null until completed.
  onboardingProfile   Json?
  /// Set when user finishes onboarding; null means redirect to /onboarding.
  onboardingCompletedAt DateTime?
  /// After phone OTP signup, false until user picks Learn vs Teach on /choose-role (or completes join-via-invite).
  intentChosen        Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  coursesTeaching     Course[]      @relation("InstructorCourses")
  enrollments         Enrollment[]
  favorites           Favorite[]
  reviews             Review[]
  lessonProgress      LessonProgress[]
  announcements       CourseAnnouncement[] @relation("AnnouncementAuthor")
  questionsAsked      CourseQuestion[]     @relation("QuestionAsker")
  answersGiven        CourseQuestion[]     @relation("QuestionAnswerer")
  assignmentSubmissions AssignmentSubmission[]
  taxProfile          InstructorTaxProfile?
  payoutRequests      PayoutRequest[]
}

model Course {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  description    String
  category       String
  format         CourseFormat
  locationLabel  String
  city           String?
  durationLabel  String
  priceCents     Int
  outcomes       String?
  imageKey       String
  coverImageUrl  String?
  rating         Float
  studentCount   Int
  badge          String?
  plannerTag     String?
  published      Boolean        @default(true)
  /// Short code for invite links (lazy-generated if null)
  inviteCode     String?        @unique
  instructorId   String
  instructor     User           @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
  favorites      Favorite[]
  reviews        Review[]
  sections       CourseSection[]
  announcements  CourseAnnouncement[]
  questions      CourseQuestion[]
  assignments    CourseAssignment[]
  classSessions  ClassSession[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Enrollment {
  id                  String                 @id @default(cuid())
  userId              String
  courseId            String
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt           DateTime               @default(now())
  attendanceRecords   AttendanceRecord[]
  feePeriods          EnrollmentFeePeriod[]

  @@unique([userId, courseId])
}

model ClassSession {
  id         String               @id @default(cuid())
  courseId   String
  course     Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  heldAt     DateTime
  label      String?
  createdAt  DateTime             @default(now())
  attendance AttendanceRecord[]

  @@index([courseId])
}

model AttendanceRecord {
  id           String       @id @default(cuid())
  sessionId    String
  enrollmentId String
  session      ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  present      Boolean      @default(false)

  @@unique([sessionId, enrollmentId])
}

/// Monthly fee tracking per enrollment (manual MVP — no payment gateway)
model EnrollmentFeePeriod {
  id             String             @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment         @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  yearMonth      String
  status         FeePaymentStatus   @default(PENDING)
  note           String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([enrollmentId, yearMonth])
  @@index([enrollmentId])
}

model OtpChallenge {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  /// When set, OTP verifies linking this phone to the signed-in user (not passwordless login).
  linkUserId String?
  createdAt  DateTime @default(now())

  @@index([phone])
  @@index([linkUserId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  rating     Int
  comment    String?
  reported   Boolean  @default(false)
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseSection {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id           String           @id @default(cuid())
  sectionId    String
  title        String
  durationMin  Int
  videoUrl     String?
  preview      Boolean          @default(false)
  sortOrder    Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  section      CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progressRows LessonProgress[]
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model CourseAnnouncement {
  id        String   @id @default(cuid())
  courseId  String
  authorId  String
  title     String?
  body      String
  emailed   Boolean  @default(false)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author    User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseQuestion {
  id               String    @id @default(cuid())
  courseId         String
  userId           String
  body             String
  createdAt        DateTime  @default(now())
  answer           String?
  answeredAt       DateTime?
  answeredByUserId String?
  course           Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user             User      @relation("QuestionAsker", fields: [userId], references: [id], onDelete: Cascade)
  answeredBy       User?     @relation("QuestionAnswerer", fields: [answeredByUserId], references: [id], onDelete: SetNull)

  @@index([courseId])
}

model CourseAssignment {
  id          String   @id @default(cuid())
  courseId  String
  title       String
  description String
  dueAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([courseId])
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  userId       String
  content      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignment   CourseAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
}

model InstructorTaxProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  legalName String?
  panLast4  String?
  gstin     String?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id               String              @id @default(cuid())
  instructorId     String
  amountCents      Int
  status           PayoutRequestStatus @default(PENDING)
  instructorNote   String?
  adminNote        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  instructor       User                @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@index([status])
}
