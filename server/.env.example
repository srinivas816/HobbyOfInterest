# Copy this file to `.env` in the same folder and fill in real values.
# The API only loads `.env` — this example file is never read at runtime.

# Database — PostgreSQL (local example matches server/docker-compose.yml)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_URL="postgresql://skillshare:skillshare@localhost:5432/skillshare_hub?schema=public"

# API
PORT=3001

# Auth — required in production (long random string)
JWT_SECRET="change-me-in-production-use-long-random-string"

# Admin moderation — comma-separated emails allowed to call /api/admin/*
ADMIN_EMAILS="admin@demo.com"

# CORS — comma-separated frontend origins (no trailing slashes)
# Production example: https://your-app.vercel.app,https://your-app.netlify.app
CORS_ORIGIN="http://localhost:8080,http://127.0.0.1:8080"

# Cloudinary (instructor uploads: course covers + lesson videos)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional folder prefix in your Cloudinary account
CLOUDINARY_UPLOAD_FOLDER="skillshare-hub"

# Google Gemini (optional — used first for onboarding if set; get a key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
# Alias some teams use:
# GOOGLE_AI_API_KEY=""
# Default model: gemini-2.0-flash (override if your project uses another allowed model)
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional — fallback after Gemini when OPENAI_API_KEY is set)
OPENAI_API_KEY=""
# OPENAI_MODEL=gpt-4o-mini

# Optional SMS — when unset (or non-production), the API returns demoOtp for on-screen entry in the app
# SMS_API_KEY=""
# Force-hide on-screen OTP even without SMS: DEMO_OTP_ON_SCREEN=0
# DEMO_OTP_ON_SCREEN=""

# Optional SMTP — bulk email when instructors post announcements with "Email learners"
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# Non-production only: Settings → “Activate Pro (trial)” with intent logging (never set when NODE_ENV=production)
# Instructors must answer a pricing-intent question; “would pay” grants Pro without Razorpay for pilots / QA.
# CHECKOUT_DEV_BYPASS=1

# Razorpay — when both are set, Instructor Pro uses real Orders API + HMAC signature verify on /confirm
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# If you verify webhooks:
# RAZORPAY_WEBHOOK_SECRET=""

# Instructor free tier (set INSTRUCTOR_ENFORCE_CAP=1 to block new learners past the cap after trial)
# INSTRUCTOR_ENFORCE_CAP=0
# INSTRUCTOR_FREE_TRIAL_DAYS=7
# INSTRUCTOR_FREE_LEARNER_CAP=10
